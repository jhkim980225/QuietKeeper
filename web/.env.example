# QuietKeeper web — Firebase configuration
#
# Copy this file to `.env` and fill in the values from your Firebase project
# (Project settings -> General -> Your apps -> SDK setup and configuration).
#
# With NO `.env` present, the app runs in mock/demo mode (in-memory fake data)
# and still builds & runs. The moment VITE_FIREBASE_API_KEY + _PROJECT_ID +
# _APP_ID are set, it switches to the real Firestore data source.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Which device document to read/write (devices/{id}). Defaults to "device-001".
VITE_QK_DEVICE_ID=device-001
